# Application
ENVIRONMENT=development
API_PORT=8000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=your_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Pipeline tuning
PIPELINE_RUN_LOCK_TTL_SECONDS=900
PIPELINE_LAST_RUN_TTL_SECONDS=86400
PIPELINE_EVENT_DEDUPE_TTL_SECONDS=21600
GLOBAL_INGESTION_RUN_LOCK_TTL_SECONDS=1800
GLOBAL_INGESTION_LAST_RUN_TTL_SECONDS=604800
GLOBAL_INGESTION_DEFAULT_DAYS_RANGE=14
GLOBAL_INGESTION_SCHEDULER_INTERVAL_SECONDS=900
GLOBAL_INGESTION_SCHEDULE_HOUR_UTC=6
GLOBAL_CATALOG_RETENTION_DAYS=45
GLOBAL_CATALOG_CLEANUP_BATCH_SIZE=1000
GLOBAL_CATALOG_CLEANUP_INTERVAL_SECONDS=900
GLOBAL_CATALOG_CLEANUP_SCHEDULE_HOUR_UTC=7
GLOBAL_CATALOG_CLEANUP_LAST_RUN_TTL_SECONDS=604800

# ATS sources (comma-separated handles)
ATS_GREENHOUSE_BOARDS=
ATS_LEVER_COMPANIES=
ATS_ASHBY_ORGANIZATIONS=
ATS_BREEZY_ORGANIZATIONS=
ATS_SMARTRECRUITERS_COMPANIES=
ATS_RECRUITEE_COMPANIES=
# Workable / Gupy / Workday require per-tenant tokens. Without them the
# unofficial scraping fallback only returns titles, which the relevance
# pipeline filters out. Leave empty unless you have proper API access.
ATS_WORKABLE_COMPANIES=
ATS_WORKABLE_API_TOKEN=
ATS_GUPY_COMPANIES=
ATS_GUPY_API_TOKEN=
ATS_WORKDAY_COMPANIES=
# Disable to run only official/documented connectors
ATS_ENABLE_UNOFFICIAL_SOURCES=true
ATS_MAX_JOBS_PER_SOURCE=200
ATS_ENABLE_MOCK_FALLBACK=true
INGESTION_RELEVANCE_ENABLED=true
INGESTION_RELEVANCE_THRESHOLD=0.35
INGESTION_RELEVANCE_EXPLORATION_RATE=0.15
INGESTION_RELEVANCE_MIN_JOBS=300
INGESTION_ATS_EXPAND_ENABLED=true
INGESTION_ATS_EXPAND_MIN_JOBS=40
INGESTION_ATS_EXPAND_DAYS_RANGE=30

# AI (tyr-agent)
OPENAI_API_KEY=
AI_TYR_MODEL=gpt-5.1
AI_REQUEST_TIMEOUT_SECONDS=30
AI_SCORING_ENABLED=true
AI_SCORING_WEIGHT=0.20
AI_DETERMINISTIC_WEIGHT=0.80
AI_MIN_CONFIDENCE=0.45
AI_MIN_CONTEXT_QUALITY=0.50
AI_MAX_EFFECTIVE_WEIGHT=0.40
AI_SCORING_MIN_DETERMINISTIC_SCORE=45
AI_SCORING_MIN_ROLE_MATCH=0.15
AI_SCORING_MIN_SKILL_OVERLAP=0.10
AI_SCORING_MIN_LOCATION_SIGNAL=0.20
AI_SCORING_MIN_WORK_MODEL_SIGNAL=0.20
AI_SCORING_MAX_SENIORITY_GAP=2
AI_MAX_CALLS_PER_RUN=75
AI_SCORING_CACHE_ENABLED=true
AI_SCORE_DESCRIPTION_MAX_CHARS=700
AI_SCORE_REQUIREMENTS_MAX_CHARS=700
AI_SCORE_SUMMARY_MAX_CHARS=400

# Resume upload
RESUME_MAX_FILE_SIZE_BYTES=5242880
RESUME_ALLOWED_MIME_TYPES=application/pdf
RESUME_MIN_EXTRACTED_TEXT_CHARS=80
RESUME_AI_MAX_INPUT_CHARS=12000

# JWT
SECRET_KEY=change_this_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your@email.com

