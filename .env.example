# Application
ENVIRONMENT=development
API_PORT=8000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=your_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Pipeline tuning
PIPELINE_RUN_LOCK_TTL_SECONDS=900
PIPELINE_LAST_RUN_TTL_SECONDS=86400
PIPELINE_EVENT_DEDUPE_TTL_SECONDS=21600
PIPELINE_RETRY_MAX_ATTEMPTS=3
PIPELINE_RETRY_BASE_DELAY_SECONDS=2

# ATS sources (comma-separated handles)
ATS_GREENHOUSE_BOARDS=
ATS_LEVER_COMPANIES=
ATS_ASHBY_ORGANIZATIONS=
ATS_MAX_JOBS_PER_SOURCE=30
ATS_ENABLE_MOCK_FALLBACK=true

# AI (tyr-agent)
OPENAI_API_KEY=
AI_TYR_MODEL=quality
AI_REQUEST_TIMEOUT_SECONDS=30
AI_SCORING_ENABLED=true
AI_SCORING_WEIGHT=0.20
AI_DETERMINISTIC_WEIGHT=0.80

# Resume upload
RESUME_MAX_FILE_SIZE_BYTES=5242880
RESUME_ALLOWED_MIME_TYPES=application/pdf
RESUME_MIN_EXTRACTED_TEXT_CHARS=80
RESUME_AI_MAX_INPUT_CHARS=12000

# JWT
SECRET_KEY=change_this_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your@email.com
